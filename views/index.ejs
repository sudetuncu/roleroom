<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="RoleRoom — A real-time roleplay chat game." />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/roleroom-page-bg.css" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            display: ['Cinzel Decorative', 'serif'],
            cinzel: ['Cinzel', 'Cinzel Decorative', 'serif'],
          },
        }
      }
    };
  </script>
  <style>
    /* ── Main panel (mockup: frosted purple, neon border, corner accents) ── */
    .rr-panel {
      position: relative;
      width: 100%;
      max-width: 52rem;
      padding: 1.75rem 1.5rem 1.5rem;
      border-radius: 1.35rem;
      background: linear-gradient(168deg, rgba(32, 18, 52, 0.94) 0%, rgba(12, 6, 24, 0.96) 55%, rgba(18, 10, 36, 0.95) 100%);
      border: 1px solid rgba(186, 140, 255, 0.42);
      box-shadow:
        0 0 0 1px rgba(99, 60, 180, 0.35),
        0 0 80px rgba(124, 58, 237, 0.28),
        0 20px 56px rgba(0, 0, 0, 0.55),
        inset 0 1px 0 rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(22px);
      -webkit-backdrop-filter: blur(22px);
    }
    .scr::-webkit-scrollbar { width: 5px; }
    .scr::-webkit-scrollbar-track { background: transparent; }
    .scr::-webkit-scrollbar-thumb { background: rgba(168,85,247,0.25); border-radius: 8px; }
    .scr::-webkit-scrollbar-thumb:hover { background: rgba(168,85,247,0.5); }
    .rr-panel::after {
      content: "";
      position: absolute;
      left: 8%;
      right: 8%;
      bottom: -2px;
      height: 48px;
      pointer-events: none;
      background: radial-gradient(ellipse 80% 100% at 50% 0%, rgba(139, 92, 246, 0.35), transparent 72%);
      filter: blur(12px);
      opacity: 0.85;
      z-index: 0;
    }
    .rr-corner {
      position: absolute;
      width: 22px;
      height: 22px;
      pointer-events: none;
      z-index: 2;
      border-color: rgba(192, 160, 255, 0.55);
    }
    .rr-corner-tl { top: 12px; left: 12px; border-top: 2px solid; border-left: 2px solid; border-radius: 6px 0 0 0; }
    .rr-corner-tr { top: 12px; right: 12px; border-top: 2px solid; border-right: 2px solid; border-radius: 0 6px 0 0; }
    .rr-corner-bl { bottom: 12px; left: 12px; border-bottom: 2px solid; border-left: 2px solid; border-radius: 0 0 0 6px; }
    .rr-corner-br { bottom: 12px; right: 12px; border-bottom: 2px solid; border-right: 2px solid; border-radius: 0 0 6px 0; }

    .rr-panel-inner { position: relative; z-index: 3; }

    /* Top ribbon */
    .rr-prehead {
      font-family: Cinzel, serif;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 0.85rem;
      background: linear-gradient(90deg, #a08040, #f0d78c 40%, #fff8e0 50%, #f0d78c 60%, #a08040);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 8px rgba(212, 175, 55, 0.35));
    }

    /* Emblem: purple aura + crown + golden masks */
    .rr-emblem-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 0.35rem;
    }
    .rr-emblem-aura {
      position: relative;
      width: 5.5rem;
      height: 5.5rem;
      border-radius: 9999px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(circle at 50% 40%, rgba(180, 120, 255, 0.35) 0%, transparent 55%),
        radial-gradient(circle at 50% 100%, rgba(20, 8, 40, 0.95), rgba(6, 2, 14, 1));
      border: 2px solid rgba(168, 120, 255, 0.55);
      box-shadow:
        0 0 0 1px rgba(251, 191, 36, 0.2),
        0 0 32px rgba(139, 92, 246, 0.55),
        0 0 56px rgba(91, 33, 182, 0.35),
        inset 0 0 24px rgba(0, 0, 0, 0.45);
    }
    @keyframes rrSealFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); }
    }
    .rr-emblem-aura.rr-float { animation: rrSealFloat 4.5s ease-in-out infinite; }

    .rr-crown-on-ring {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      width: 28px;
      height: 22px;
      z-index: 4;
      filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.6));
    }

    /* Brand: metallic + interlocking OO */
    .rr-brand {
      font-family: "Cinzel Decorative", Cinzel, serif;
      font-weight: 900;
      font-size: clamp(1.85rem, 7vw, 2.45rem);
      line-height: 1;
      display: flex;
      align-items: baseline;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
      margin-top: 0.35rem;
      margin-bottom: 0.25rem;
      letter-spacing: 0.02em;
      background: linear-gradient(95deg, #d8b4fe 0%, #fef3c7 28%, #e9d5ff 45%, #fcd34d 62%, #c4b5fd 100%);
      background-size: 160% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 2px 12px rgba(124, 58, 237, 0.45));
    }
    .rr-brand .rr-oo {
      display: inline-flex;
      align-items: baseline;
      margin: 0 -0.02em;
      position: relative;
    }
    .rr-brand .rr-oo span {
      display: inline-block;
      -webkit-text-fill-color: transparent;
      background: linear-gradient(180deg, #fff8e7 0%, #e8c547 45%, #b8860b 100%);
      -webkit-background-clip: text;
      background-clip: text;
    }
    .rr-brand .rr-oo .oo1 { margin-right: -0.38em; z-index: 2; position: relative; }
    .rr-brand .rr-oo .oo2 { margin-left: -0.02em; z-index: 1; position: relative; opacity: 0.96; }

    .rr-subtitle {
      font-family: Cinzel, serif;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(245, 240, 255, 0.88);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 0.35rem;
    }
    .rr-subtitle .rr-line {
      flex: 1;
      max-width: 3rem;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(192, 160, 255, 0.55));
    }
    .rr-subtitle .rr-line-r {
      background: linear-gradient(270deg, transparent, rgba(192, 160, 255, 0.55));
    }
    .rr-diamond { color: rgba(212, 175, 120, 0.85); font-size: 0.45rem; }

    /* Input row + user icon */
    .rr-field-label {
      font-family: Cinzel, serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(196, 181, 220, 0.9);
      margin-bottom: 0.45rem;
    }
    .rr-input-shell {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      color: rgba(168, 140, 210, 0.55);
      border-radius: 0.85rem;
      background: rgba(8, 4, 18, 0.88);
      border: 1px solid rgba(160, 120, 230, 0.4);
      padding: 0.35rem 0.85rem 0.35rem 0.65rem;
      box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.35), 0 0 18px rgba(124, 58, 237, 0.12);
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .rr-input-shell:focus-within {
      border-color: rgba(192, 160, 255, 0.65);
      box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.3), 0 0 28px rgba(139, 92, 246, 0.28);
    }
    .rr-input-shell svg { flex-shrink: 0; }
    .rr-input-shell input {
      flex: 1;
      min-width: 0;
      background: transparent;
      border: none;
      outline: none;
      color: #f1edfa;
      font-size: 0.9rem;
      padding: 0.65rem 0.25rem;
    }
    .rr-input-shell input::placeholder { color: rgba(148, 140, 170, 0.75); }

    /* Pill CTA — gold frame + gold type */
    .rr-enter-btn {
      width: 100%;
      margin-top: 0.25rem;
      border-radius: 9999px;
      padding: 0.95rem 1.5rem;
      font-family: Cinzel, serif;
      font-weight: 700;
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      position: relative;
      box-shadow:
        0 0 0 1px rgba(212, 175, 55, 0.45),
        0 0 24px rgba(124, 58, 237, 0.25),
        0 6px 20px rgba(0, 0, 0, 0.45),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
      background: linear-gradient(180deg, #453070 0%, #2a1848 48%, #160c28 100%);
      border: 2px solid #c9a44a;
      color: #f8ecc8;
      text-shadow: 0 0 20px rgba(212, 175, 55, 0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.65rem;
      cursor: pointer;
      transition: transform 0.18s ease, filter 0.18s ease, box-shadow 0.18s ease;
    }
    .rr-enter-btn:hover {
      filter: brightness(1.1);
      box-shadow:
        0 0 0 1px rgba(255, 230, 160, 0.55),
        0 0 36px rgba(139, 92, 246, 0.35),
        0 8px 28px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      transform: translateY(-2px);
    }
    .rr-enter-btn:active { transform: translateY(0); }

    /* Role pills */
    .rr-pills {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.45rem;
      margin-top: 1.35rem;
    }
    .rr-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.38rem 0.65rem;
      border-radius: 9999px;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-family: Cinzel, serif;
      background: rgba(8, 4, 18, 0.75);
      border: 1px solid;
      color: rgba(230, 225, 245, 0.9);
    }
    .rr-pill-d { border-color: rgba(96, 165, 250, 0.55); color: #93c5fd; }
    .rr-pill-o { border-color: rgba(74, 222, 128, 0.5); color: #86efac; }
    .rr-pill-k { border-color: rgba(248, 113, 113, 0.55); color: #fca5a5; }
    .rr-pill-s { border-color: rgba(192, 132, 252, 0.55); color: #e9d5ff; }

    .rr-foot-note {
      text-align: center;
      font-size: 0.62rem;
      color: rgba(148, 140, 170, 0.75);
      margin-top: 0.75rem;
      letter-spacing: 0.04em;
    }
  </style>
</head>
<body class="rr-page min-h-screen font-sans text-slate-100 flex items-center justify-center p-4 sm:p-6 relative">
  <div class="rr-panel relative z-10">
    <span class="rr-corner rr-corner-tl" aria-hidden="true"></span>
    <span class="rr-corner rr-corner-tr" aria-hidden="true"></span>
    <span class="rr-corner rr-corner-bl" aria-hidden="true"></span>
    <span class="rr-corner rr-corner-br" aria-hidden="true"></span>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-300/50 to-transparent z-[4]" aria-hidden="true"></div>

    <div class="rr-panel-inner">
      <p class="rr-prehead"><span class="rr-diamond">◆</span> ENTER THE REALM <span class="rr-diamond">◆</span></p>

      <div class="rr-emblem-wrap">
        <div class="rr-emblem-aura rr-float">
          <svg class="rr-crown-on-ring" viewBox="0 0 28 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <linearGradient id="idx-crown" x1="4" y1="2" x2="24" y2="20" gradientUnits="userSpaceOnUse">
                <stop stop-color="#fff8e0"/><stop offset="0.4" stop-color="#e8c547"/><stop offset="1" stop-color="#8a6820"/>
              </linearGradient>
            </defs>
            <path d="M14 3l2.5 5 4.5-3.5-1.2 7H8.2L7 4.5l4.5 3.5L14 3z" fill="url(#idx-crown)" stroke="#5c4518" stroke-width="0.5"/>
            <path d="M5 15.5h18v3.5H5v-3.5z" fill="url(#idx-crown)" stroke="#4a3810" stroke-width="0.45"/>
          </svg>
          <svg width="52" height="44" viewBox="0 0 52 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <linearGradient id="idx-mask-gold" x1="0" y1="0" x2="52" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#fff8e0"/><stop offset="0.35" stop-color="#e8c960"/><stop offset="0.7" stop-color="#c9a227"/><stop offset="1" stop-color="#8a6820"/>
              </linearGradient>
            </defs>
            <!-- Comedy mask (left) -->
            <path d="M18 34c-8 0-12-5-12-12 0-8 5-14 14-14s14 6 14 14c0 7-4 12-12 12z" stroke="url(#idx-mask-gold)" stroke-width="1.4" fill="rgba(40,28,18,0.25)"/>
            <ellipse cx="13" cy="22" rx="2.4" ry="2.8" fill="url(#idx-mask-gold)"/>
            <ellipse cx="23" cy="22" rx="2.4" ry="2.8" fill="url(#idx-mask-gold)"/>
            <path d="M12 27c3 5 9 5 12 0" stroke="url(#idx-mask-gold)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
            <!-- Tragedy mask (right, overlap) -->
            <path d="M34 34c8 0 12-5 12-12 0-8-5-14-14-14s-14 6-14 14c0 7 4 12 12 12z" stroke="url(#idx-mask-gold)" stroke-width="1.4" fill="rgba(40,28,18,0.2)"/>
            <ellipse cx="29" cy="22" rx="2.4" ry="2.8" fill="url(#idx-mask-gold)"/>
            <ellipse cx="39" cy="22" rx="2.4" ry="2.8" fill="url(#idx-mask-gold)"/>
            <path d="M30 29c4-3 8-3 12 0" stroke="url(#idx-mask-gold)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
      </div>

      <h1 class="rr-brand">
        <span>ROLER</span><span class="rr-oo"><span class="oo1">O</span><span class="oo2">O</span></span><span>M</span>
      </h1>
      <div class="rr-subtitle">
        <span class="rr-line" aria-hidden="true"></span>
        <span class="rr-diamond">◆</span>
        <span>LIVE ACTION ROLEPLAY</span>
        <span class="rr-diamond">◆</span>
        <span class="rr-line rr-line-r" aria-hidden="true"></span>
      </div>

      <% if (error) { %>
        <div class="mt-5 rounded-xl bg-red-500/15 border border-red-400/35 px-4 py-3 text-sm text-red-300">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <div class="mt-7 flex flex-col md:flex-row gap-8">
        
        <!-- LEFT COLUMN: Avatar Selection -->
        <div class="flex-1 flex flex-col">
          <label class="rr-field-label block text-center mb-3">CHOOSE YOUR AVATAR</label>
          <div class="grid grid-cols-3 sm:grid-cols-4 gap-3 max-h-[320px] overflow-y-auto scr pr-2 flex-1" id="avatar-grid">
            <% if (typeof avatars !== 'undefined' && avatars.length > 0) { %>
              <% avatars.forEach(function(avatar, index) { %>
                <div class="avatar-option rounded-xl overflow-hidden cursor-pointer border-2 border-transparent hover:border-purple-400/80 transition-all opacity-80 hover:opacity-100" data-avatar="<%= avatar %>">
                  <img src="/avatars/<%= avatar %>" alt="Avatar" class="w-full h-auto object-cover aspect-square">
                </div>
              <% }); %>
            <% } else { %>
              <div class="col-span-4 text-center text-xs text-purple-300/50 py-10">No avatars found in Avatars folder.</div>
            <% } %>
          </div>
        </div>

        <!-- RIGHT COLUMN: Form & How to play -->
        <div class="flex-1 flex flex-col justify-center">
          <form method="post" action="/join" class="space-y-4">
            <input type="hidden" name="avatar" id="selected-avatar" value="">
            <div>
              <label class="rr-field-label block" for="username">ADVENTURER NAME</label>
              <div class="rr-input-shell">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 12a4 4 0 100-8 4 4 0 000 8z" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M4 20a8 8 0 0116 0" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                <input
                  id="username"
                  name="username"
                  type="text"
                  maxlength="32"
                  autocomplete="off"
                  required
                  placeholder="Enter your name..."
                />
              </div>
            </div>
            <button type="submit" class="rr-enter-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="idx-blade" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#fff8e0"/><stop offset="0.5" stop-color="#e8c547"/><stop offset="1" stop-color="#a08040"/>
                  </linearGradient>
                </defs>
                <path d="M12 2v20M8 6h8M7 5l10 14M17 5L7 19" stroke="url(#idx-blade)" stroke-width="1.15" stroke-linecap="round"/>
              </svg>
              <span>ENTER THE REALM</span>
            </button>
          </form>

          <div class="rr-pills mt-4" aria-hidden="true">
            <span class="rr-pill rr-pill-d">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M20 20l-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Detective
            </span>
            <span class="rr-pill rr-pill-o">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 4v4M12 16v4M8 12H4M20 12h-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Doctor
            </span>
            <span class="rr-pill rr-pill-k">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 4l12 16M18 4L6 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Killer
            </span>
            <span class="rr-pill rr-pill-s">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="11" rx="7" ry="8" stroke="currentColor" stroke-width="1.4"/><path d="M9 10h.01M15 10h.01M8 14c2 3 6 3 8 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              Spy
            </span>
          </div>

          <div class="mt-6 p-4 rounded-xl bg-[#080412]/60 border border-purple-400/20 shadow-inner">
            <h3 class="text-[10px] font-bold tracking-widest text-amber-200/90 uppercase mb-2">How to Play</h3>
            <ul class="text-[11px] text-slate-300/90 space-y-1.5 list-disc pl-4">
              <li>A random role is assigned to you upon joining.</li>
              <li>Each role has secret keywords. Use them in your messages for <span class="text-emerald-400 font-bold">+10 pts</span>.</li>
              <li>Failing to act your role loses you <span class="text-red-400 font-bold">-5 pts</span>.</li>
              <li>At the end of each round, an AI Narrator will declare a winner!</li>
            </ul>
          </div>

        </div>
      </div>

    </div>
  </div>

  <script>
    const avatarOptions = document.querySelectorAll('.avatar-option');
    const selectedAvatarInput = document.getElementById('selected-avatar');
    avatarOptions.forEach(opt => {
      opt.addEventListener('click', () => {
        avatarOptions.forEach(o => {
          o.classList.remove('border-purple-400', 'shadow-[0_0_15px_rgba(168,85,247,0.5)]', 'opacity-100');
          o.classList.add('border-transparent', 'opacity-80');
        });
        opt.classList.remove('border-transparent', 'opacity-80');
        opt.classList.add('border-purple-400', 'shadow-[0_0_15px_rgba(168,85,247,0.5)]', 'opacity-100');
        selectedAvatarInput.value = opt.dataset.avatar;
      });
    });
    if (avatarOptions.length > 0) {
      avatarOptions[0].click();
    }
  </script>
</body>
</html>
