<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="RoleRoom — Real-time roleplay chat game room" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/roleroom-page-bg.css" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            display: ['Cinzel Decorative', 'serif']
          },
        }
      }
    };
  </script>
  <style>
    /* ── Theme Variables ── */
    :root {
      --theme-bg: 20, 14, 40;
      --theme-border: 160, 120, 230;
      --theme-glow: 139, 92, 246;
    }
    
    .theme-detective { --theme-bg: 10, 20, 35; --theme-border: 96, 165, 250; --theme-glow: 59, 130, 246; }
    .theme-doctor { --theme-bg: 10, 30, 20; --theme-border: 74, 222, 128; --theme-glow: 34, 197, 94; }
    .theme-killer { --theme-bg: 35, 10, 15; --theme-border: 248, 113, 113; --theme-glow: 239, 68, 68; }
    .theme-spy { --theme-bg: 25, 10, 35; --theme-border: 192, 132, 252; --theme-glow: 168, 85, 247; }

    /* ── Glass Panels ── */
    .glass {
      background: rgba(var(--theme-bg), 0.72);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(var(--theme-border), 0.22);
      transition: background 0.5s, border-color 0.5s;
    }
    .glass-strong {
      background: rgba(var(--theme-bg), 0.85);
      backdrop-filter: blur(22px);
      -webkit-backdrop-filter: blur(22px);
      border: 1px solid rgba(var(--theme-border), 0.35);
      transition: background 0.5s, border-color 0.5s;
    }

    /* ── Scrollbar ── */
    .scr::-webkit-scrollbar { width: 5px; }
    .scr::-webkit-scrollbar-track { background: transparent; }
    .scr::-webkit-scrollbar-thumb { background: rgba(168,85,247,0.25); border-radius: 8px; }
    .scr::-webkit-scrollbar-thumb:hover { background: rgba(168,85,247,0.5); }

    /* ── Animations ── */
    @keyframes fadeSlide { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .msg-anim { animation: fadeSlide 0.3s ease; }

    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    .shimmer-text {
      background: linear-gradient(90deg, #d8b4fe, #fef3c7, #d8b4fe);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shimmer 4s linear infinite;
    }

    /* ── Autofill fix ── */
    input:-webkit-autofill { -webkit-box-shadow: 0 0 0 30px #140e28 inset !important; -webkit-text-fill-color: #e2e8f0 !important; }

    .panel-glow {
      box-shadow:
        0 0 0 1px rgba(var(--theme-glow), 0.14),
        0 8px 32px rgba(0, 0, 0, 0.5),
        0 0 48px rgba(var(--theme-glow), 0.16);
      transition: box-shadow 0.5s;
    }
    .stat-pill {
      background: rgba(8, 5, 18, 0.72);
      border: 1px solid rgba(var(--theme-border), 0.2);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }
    .stat-pill.msg-at-cap {
      box-shadow: 0 0 0 1px rgba(251, 191, 36, 0.45), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    /* ── Atmosphere Animations ── */
    .atmosphere-layer { position: fixed; inset: 0; pointer-events: none; z-index: 1; overflow: hidden; opacity: 0; transition: opacity 2s; }
    
    .theme-detective .atmosphere-layer { opacity: 1; background: url('data:image/svg+xml;utf8,<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><filter id="noiseFilter"><feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noiseFilter)" opacity="0.1"/></svg>'); mix-blend-mode: screen; animation: panFog 60s linear infinite; }
    @keyframes panFog { from { background-position: 0 0; } to { background-position: 100vw 50vh; } }

    .theme-killer .atmosphere-layer { opacity: 1; box-shadow: inset 0 0 150px rgba(255,0,0,0.15); animation: heartbeat 2.5s infinite; }
    @keyframes heartbeat { 0%, 100% { box-shadow: inset 0 0 150px rgba(255,0,0,0.15); } 15% { box-shadow: inset 0 0 180px rgba(255,0,0,0.3); } 30% { box-shadow: inset 0 0 150px rgba(255,0,0,0.15); } 45% { box-shadow: inset 0 0 180px rgba(255,0,0,0.25); } }

    .theme-doctor .atmosphere-layer { opacity: 1; background: radial-gradient(circle at 50% 120%, rgba(34,197,94,0.15) 0%, transparent 60%); animation: pulseHeal 4s infinite alternate; }
    @keyframes pulseHeal { from { opacity: 0.5; transform: scale(1); } to { opacity: 1; transform: scale(1.05); } }

    .theme-spy .atmosphere-layer { opacity: 1; background: linear-gradient(0deg, rgba(168,85,247,0.05) 0%, transparent 2px); background-size: 100% 4px; animation: scanline 8s linear infinite; }
    @keyframes scanline { from { background-position: 0 0; } to { background-position: 0 100vh; } }
  </style>
</head>
<body class="rr-page h-screen font-sans text-slate-200 overflow-hidden flex flex-col relative">

  <!-- Data payload -->
  <div id="app-root" data-username="<%- encodeURIComponent(username) %>" data-avatar="<%- encodeURIComponent(avatar) %>" style="display:none;"></div>

  <!-- Atmosphere Layer -->
  <div class="atmosphere-layer"></div>

  <!-- ═══════════════════════════════════════════
       HEADER
       ═══════════════════════════════════════════ -->
  <header class="relative z-30 shrink-0 flex items-center justify-between px-4 sm:px-5 py-3 glass-strong border-b border-purple-400/15">

    <!-- LEFT: Current user card -->
    <div class="flex items-center gap-3 glass rounded-xl px-3 py-2 panel-glow max-w-[min(100%,220px)] sm:max-w-none" id="header-user-card">
      <div id="header-avatar" class="w-10 h-10 rounded-full border-2 border-purple-400/60 bg-purple-900/40 flex items-center justify-center text-lg relative shrink-0">
        🎭
        <span class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 bg-emerald-400 rounded-full border-2 border-[#0f0a18] shadow-[0_0_6px_rgba(52,211,153,0.6)]"></span>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-bold text-slate-100 truncate" id="header-username"><%= username %></p>
        <span id="header-role-badge" class="text-[10px] font-bold px-2 py-0.5 rounded-md inline-block mt-0.5" style="background:rgba(168,85,247,0.2);color:#d8b4fe;">…</span>
      </div>
      <div class="ml-1 sm:ml-2 text-sm font-bold text-amber-300 flex items-center gap-1 shrink-0"><span class="text-base leading-none" aria-hidden="true">🪙</span><span id="header-score">0</span></div>
    </div>

    <!-- CENTER: Logo -->
    <div class="absolute left-1/2 -translate-x-1/2 flex flex-col items-center pointer-events-none select-none">
      <div class="flex flex-col items-center gap-0 text-amber-400/95 mb-0.5 drop-shadow-[0_0_14px_rgba(251,191,36,0.35)]">
        <span class="text-base leading-none">👑</span>
        <span class="text-lg leading-none -mt-0.5">⚔️</span>
      </div>
      <h1 class="font-display text-[1.35rem] sm:text-2xl shimmer-text tracking-wider leading-tight">RoleRoom</h1>
      <span class="text-[8px] sm:text-[9px] tracking-[0.22em] text-purple-300/65 mt-1 font-semibold">LIVE ACTION ROLEPLAY</span>
    </div>

    <!-- RIGHT: Info pills + actions -->
    <div class="flex items-center gap-1.5 sm:gap-2 flex-wrap justify-end max-w-[42%] sm:max-w-none">
      <div class="stat-pill rounded-lg px-2.5 sm:px-3 py-2 flex items-center gap-1.5 text-[10px] sm:text-xs">
        <span class="text-purple-300 shrink-0" aria-hidden="true">⚔️</span>
        <span class="text-slate-500 hidden sm:inline">Round</span>
        <span class="font-bold text-purple-100 tabular-nums" id="top-round">1/10</span>
      </div>
      <div class="stat-pill rounded-lg px-2.5 sm:px-3 py-2 flex items-center gap-1.5 text-[10px] sm:text-xs">
        <span class="text-amber-400/90 shrink-0" aria-hidden="true">⏳</span>
        <span class="text-slate-500 hidden sm:inline">Time</span>
        <span class="font-bold font-mono text-sky-300 tabular-nums" id="round-timer">00:00</span>
      </div>
      <div class="stat-pill rounded-lg px-2.5 sm:px-3 py-2 flex items-center gap-1.5 text-[10px] sm:text-xs" id="stat-pill-msgs">
        <span class="text-violet-300 shrink-0" aria-hidden="true">💬</span>
        <span class="text-slate-500 hidden sm:inline">Msgs</span>
        <span class="font-bold text-violet-100 tabular-nums" id="top-msgs">0/40</span>
      </div>
      <button type="button" id="btn-new-game" class="rounded-lg px-2.5 sm:px-4 py-2 text-[10px] sm:text-xs font-bold text-white bg-gradient-to-r from-purple-600 to-violet-700 border border-purple-400/45 shadow-md shadow-purple-900/40 hover:shadow-lg hover:shadow-purple-600/35 hover:scale-[1.03] active:scale-[0.97] transition-all flex items-center gap-1">
        <span aria-hidden="true">⚔️</span><span class="hidden sm:inline">Start New Game</span><span class="sm:hidden">New</span>
      </button>
      <a href="/" class="rounded-lg px-2.5 sm:px-4 py-2 text-[10px] sm:text-xs font-bold text-red-200/95 bg-red-950/55 border border-red-500/30 hover:bg-red-900/45 hover:border-red-400/40 transition-all flex items-center gap-1 shadow-inner">
        <span aria-hidden="true">🚪</span><span class="hidden sm:inline">Leave</span>
      </a>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════
       MAIN 3-COLUMN LAYOUT
       ═══════════════════════════════════════════ -->
  <main class="flex-1 flex gap-3 sm:gap-4 p-3 sm:p-4 overflow-hidden min-h-0 relative z-10">

    <!-- ── LEFT PANEL: Players + Your Role ── -->
    <aside class="w-[240px] sm:w-[260px] shrink-0 flex flex-col gap-3 sm:gap-4 min-h-0">

      <!-- Players Panel -->
      <div class="glass panel-glow rounded-2xl flex flex-col flex-1 min-h-0 overflow-hidden">
        <div class="px-4 py-3 border-b border-purple-400/15 flex items-center justify-between">
          <h2 class="text-[11px] font-extrabold tracking-[0.2em] text-slate-200 uppercase">Players</h2>
          <span class="text-[10px] font-bold text-purple-200 bg-purple-950/50 border border-purple-500/25 px-2 py-0.5 rounded-full tabular-nums" id="player-count">0/10</span>
        </div>
        <ul id="user-list" class="flex-1 overflow-y-auto scr p-2.5 space-y-0.5"></ul>
      </div>

      <!-- Your Role Card -->
      <div class="glass panel-glow rounded-2xl p-4 sm:p-5 text-center relative overflow-hidden border-t-[3px] border-t-purple-500/55" id="role-card">
        <div class="absolute inset-0 bg-gradient-to-b from-purple-600/8 to-transparent pointer-events-none"></div>
        <p class="text-[10px] font-bold tracking-[0.18em] text-purple-200/90 uppercase mb-2 relative z-10">Your role</p>
        <div id="role-icon" class="w-16 h-16 mx-auto rounded-full bg-purple-900/45 border-2 border-purple-400/55 flex items-center justify-center text-3xl shadow-[0_0_28px_rgba(168,85,247,0.35)] mb-2 relative z-10 transition-transform duration-300 hover:scale-105">🎭</div>
        <p id="my-role" class="text-lg sm:text-xl font-bold relative z-10" style="color:#d8b4fe;">…</p>
        <p id="keyword-hint" class="text-[11px] text-slate-400/95 mt-2 leading-relaxed relative z-10 px-1">Use keywords in your messages to gain points.</p>
        <button type="button" id="guide-btn" class="mt-4 w-full py-2.5 rounded-xl bg-purple-950/55 border border-purple-500/30 text-xs font-bold text-purple-100 hover:bg-purple-900/55 transition-colors relative z-10 flex items-center justify-center gap-2">
          <span aria-hidden="true">📖</span> View Role Guide
        </button>
      </div>
    </aside>

    <!-- ── CENTER: Chat ── -->
    <section class="flex-1 glass panel-glow rounded-2xl flex flex-col overflow-hidden min-h-0 min-w-0 relative">
      <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-purple-400/40 to-transparent"></div>

      <!-- Chat title -->
      <div class="px-5 py-3 border-b border-purple-400/15 flex items-center justify-center">
        <h2 class="text-xs font-bold tracking-widest text-slate-300 uppercase flex items-center gap-2">
          <span class="text-base">💬</span> Live Chat
        </h2>
      </div>

      <div id="narrator-box" class="mx-4 sm:mx-5 mt-3 px-4 py-3 rounded-xl bg-indigo-500/10 border border-indigo-400/25 flex gap-3 items-center">
        <div class="w-12 h-12 rounded-full border-2 border-indigo-400/50 overflow-hidden shrink-0 shadow-[0_0_15px_rgba(99,102,241,0.3)]">
          <img src="/images/narrator.png" alt="Narrator" class="w-full h-full object-cover">
        </div>
        <div class="flex-1">
          <p class="text-[10px] font-bold tracking-[0.14em] text-indigo-200 uppercase mb-1">Narrator says:</p>
          <p id="narrator-scenario" class="text-sm text-indigo-100/95 leading-relaxed">Waiting for next scenario...</p>
        </div>
      </div>

      <!-- Messages -->
      <div id="messages" class="flex-1 min-h-0 overflow-y-auto overflow-x-hidden overscroll-contain scr p-5 flex flex-col gap-4 [scrollbar-gutter:stable]"></div>

      <!-- Input area -->
      <div class="px-4 sm:px-5 py-4 border-t border-purple-400/15 bg-[rgba(10,6,20,0.65)]">
        <form id="chat-form" class="flex items-stretch sm:items-center gap-2 sm:gap-3">
          <div class="relative flex-1 min-w-0 flex items-center">
            <button type="button" id="emoji-toggle" class="absolute left-2.5 z-10 flex h-9 w-9 items-center justify-center rounded-lg text-lg leading-none text-slate-400 hover:bg-white/5 hover:text-slate-200 transition-colors" title="Add emoji">😊</button>
            <input
              id="message-input"
              type="text"
              maxlength="500"
              autocomplete="off"
              placeholder="Type your message... (use role keywords for +10!)"
              class="w-full rounded-xl bg-[#0c0818]/90 border border-purple-400/22 pl-12 pr-4 py-3 text-sm text-slate-100 placeholder-slate-500/55 outline-none transition-all duration-200 focus:border-purple-400/50 focus:shadow-[0_0_18px_rgba(168,85,247,0.14)]"
            />
          </div>
          <button type="submit" class="shrink-0 rounded-xl bg-gradient-to-r from-purple-600 to-violet-700 border border-purple-400/35 px-4 sm:px-5 py-3 text-sm font-bold text-white hover:shadow-lg hover:shadow-purple-600/30 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
            Send
          </button>
        </form>
      </div>
    </section>

    <!-- ── RIGHT PANEL: Game Info + Leaderboard ── -->
    <aside class="w-[260px] sm:w-[280px] shrink-0 flex flex-col gap-3 sm:gap-4 min-h-0">

      <!-- Game Info -->
      <div class="glass panel-glow rounded-2xl p-4 sm:p-5">
        <h2 class="text-[11px] font-extrabold tracking-[0.18em] text-slate-200 uppercase flex items-center gap-2 mb-4 pb-2 border-b border-purple-400/15">
          <span class="text-purple-300" aria-hidden="true">ℹ️</span> Game info
        </h2>
        <div class="space-y-3">
          <div class="flex items-center justify-between gap-2">
            <span class="text-xs text-slate-500 flex items-center gap-2">Round</span>
            <span class="text-sm font-bold text-purple-300 tabular-nums" id="info-round">1/10</span>
          </div>
          <div class="flex items-center justify-between gap-2">
            <span class="text-xs text-slate-500 flex items-center gap-2">Messages</span>
            <span class="text-sm font-bold font-mono text-violet-300 tabular-nums" id="info-msgs">0/40</span>
          </div>
          <div class="flex items-center justify-between gap-2">
            <span class="text-xs text-slate-500 flex items-center gap-2">Time left</span>
            <span class="text-sm font-bold font-mono text-sky-400 tabular-nums" id="info-timer">00:00</span>
          </div>
          <div class="flex items-center justify-between gap-2">
            <span class="text-xs text-slate-500 flex items-center gap-2"><span id="info-role-emoji">🎭</span> Your role</span>
            <span class="text-sm font-bold" id="info-role" style="color:#d8b4fe;">…</span>
          </div>
        </div>
      </div>

      <!-- Leaderboard -->
      <div class="glass panel-glow rounded-2xl flex flex-col flex-1 min-h-0 overflow-hidden">
        <div class="px-4 sm:px-5 py-3 border-b border-purple-400/15">
          <h2 class="text-[11px] font-extrabold tracking-[0.18em] text-slate-200 uppercase flex items-center gap-2">
            <span class="text-amber-400 text-base" aria-hidden="true">🏆</span> Leaderboard
          </h2>
        </div>
        <ol id="scoreboard" class="flex-1 overflow-y-auto scr p-3 space-y-2"></ol>
      </div>
    </aside>
  </main>

  <!-- Bottom tip bar -->
  <div class="shrink-0 flex justify-center py-2 sm:py-2.5 relative z-10 px-2">
    <div class="glass panel-glow rounded-full px-4 sm:px-6 py-2 flex items-center gap-2 text-[11px] sm:text-xs max-w-full">
      <span class="text-amber-400 shrink-0" aria-hidden="true">💡</span>
      <span class="text-slate-300/85 text-center sm:text-left">Tip: Use role-related keywords in your messages to earn more points!</span>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <div id="winner-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4">
    <div class="w-full max-w-md rounded-2xl border border-amber-300/30 bg-[#1a1230] p-5 shadow-2xl">
      <p class="text-[11px] font-bold tracking-[0.16em] text-amber-300 uppercase">Winner of the round</p>
      <h3 id="winner-name" class="mt-2 text-2xl font-extrabold text-amber-100">-</h3>
      <p id="winner-reason" class="mt-2 text-sm text-slate-300 leading-relaxed">-</p>
      <button id="winner-close" type="button" class="mt-4 w-full rounded-xl bg-amber-500/20 border border-amber-300/35 px-4 py-2 text-sm font-bold text-amber-100 hover:bg-amber-500/30 transition-colors">
        Continue
      </button>
    </div>
  </div>
  <script src="/js/chat-client.js"></script>
</body>
</html>
